# Server Configuration
PORT=5173

# Database Connection (MongoDB)
# Use a local MongoDB instance or a remote Atlas connection URI
MONGO_URI=mongodb://127.0.0.1:27017/campus_store

# Razorpay API Credentials
# Replace with your actual Razorpay Test/Live keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_if_any
